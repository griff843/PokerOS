{
  "name": "poker-coach-os",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "coach": "tsx apps/cli/src/index.ts",
    "dev": "pnpm dev:table-sim",
    "dev:table-sim": "pnpm --filter @poker-coach/table-sim dev",
    "dev:web": "pnpm --filter @poker-coach/table-sim dev",
    "build": "pnpm build:table-sim",
    "build:table-sim": "pnpm --filter @poker-coach/table-sim build",
    "build:web": "pnpm --filter @poker-coach/table-sim build",
    "typecheck": "pnpm exec tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "pnpm exec tsc --noEmit && pnpm test && pnpm --filter @poker-coach/table-sim build",
    "poker:ai:refresh": "tsx scripts/poker-ai-refresh.ts"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0",
    "zod": "^3.22.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  }
}
