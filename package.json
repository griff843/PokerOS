{
  "name": "poker-coach-os",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "coach": "tsx apps/cli/src/index.ts",
    "dev": "pnpm dev:table-sim",
    "dev:table-sim": "pnpm --filter @poker-coach/table-sim dev",
    "dev:web": "pnpm --filter @poker-coach/table-sim dev",
    "build": "pnpm build:table-sim",
    "build:table-sim": "pnpm --filter @poker-coach/table-sim build",
    "build:web": "pnpm --filter @poker-coach/table-sim build",
    "typecheck": "pnpm exec tsc --noEmit",
    "validate:gold-lane": "node scripts/validate-gold-lane.mjs",
    "validate:gold-json": "node scripts/validate-gold-lane.mjs --json",
    "validate:gold-seed": "node scripts/validate-gold-lane.mjs --mode=seed content/drills/live_cash_gold_btn_bb_river.json",
    "validate:canonical": "pnpm exec tsx scripts/validate-canonical-drills.ts",
    "content:init": "pnpm exec tsx apps/cli/src/index.ts init",
    "review:gold-batch": "node scripts/review-merge-gold-lane.mjs",
    "drill:scaffold": "node scripts/drill-scaffold.mjs",
    "drill:batch": "node scripts/lane-batch-generator.mjs",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "pnpm exec tsc --noEmit && pnpm test && pnpm --filter @poker-coach/table-sim build"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0",
    "zod": "^3.22.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  }
}
